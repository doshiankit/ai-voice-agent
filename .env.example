# AI Services
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=optional_openai_key

# Service Ports
STT_PORT=8001
TTS_PORT=8002
AGENT_PORT=8003
PIPELINE_PORT=8004

# ── Service URLs (used by pipeline) ────
STT_URL=http://127.0.0.1:8001
AGENT_URL=http://127.0.0.1:8003
TTS_URL=http://127.0.0.1:8002

# Audio
WHISPER_MODEL=base

#File Upload Size
MAX_UPLOAD_MB=25
